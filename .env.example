# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=research
POSTGRES_PASSWORD=research_pw
POSTGRES_DB=research_agent
DATABASE_URL=postgresql+asyncpg://research:research_pw@postgres:5432/research_agent
DATABASE_URL_SYNC=postgresql+psycopg2://research:research_pw@postgres:5432/research_agent

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Ollama (host) ───────────────────────────────────────────────────────────
# Inside docker, host.docker.internal resolves to host machine
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_to_a_random_64char_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
